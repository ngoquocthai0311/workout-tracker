{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "outputDirectory": "dist/frontend/browser",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://api.example.com/api/:path*"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}